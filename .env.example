# Copy to .env.local for Vite dev. In Cloudflare Pages, add these in
# Settings → Environment variables for Production (and Preview if needed).

VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=
VITE_SHOPIFY_API_VERSION=2024-01

# Storefront access token must include scope: unauthenticated_write_customers
# (for /account register + sign-in via customerCreate / customerAccessTokenCreate).
# Works with classic / legacy customer accounts; "new" customer accounts may use a different flow.
# For order history on /account, the same storefront app needs permission to read customer orders (see Headless channel / Storefront API scopes in Shopify admin).

# Optional: Essence collection handles (comma-separated, lowercase)
# VITE_ESSENCE_COLLECTION_HANDLES=essence,essences
